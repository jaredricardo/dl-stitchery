{%- assign color_scheme = 'color-' | append: section.settings.color_scheme -%}

{% style %}

  [data-section-id="{{ section.id }}"] {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  [data-section-id="{{ section.id }}"] .image-with-layout__col--image {
    overflow: hidden;
    max-width: 100%;
    max-height: 33vh;
  }

  [data-section-id="{{ section.id }}"] .image-with-layout__col--image img,
  [data-section-id="{{ section.id }}"] .image-with-layout__col--image .placeholder-svg {
    height: 100%;
    max-height: 33vh;
    object-fit: contain;
  }

  @media screen and (min-width: 768px) {
    [data-section-id="{{ section.id }}"] {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    [data-section-id="{{ section.id }}"] .image-with-layout__grid {
      grid-template-columns: 1.5fr 3fr 1.5fr;
    }
  }

{% endstyle %}

<section data-section-id="{{ section.id }}" class="image-with-layout {{ color_scheme }}" {% if section.settings.section_anchor_id %} id="{{ section.settings.section_anchor_id }}"{% endif %}>
  <div class="image-with-layout__grid wrapper--full-padded">

    <div class="image-with-layout__col image-with-layout__col--image">
      {% if section.settings.image_left %}
        <img
          src="{{ section.settings.image_left | image_url: width: 800 }}"
          alt="{{ section.settings.image_left_alt | default: section.settings.image_left.alt | escape }}"
          loading="lazy"
        >
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>

    <div class="image-with-layout__col image-with-layout__col--content image-with-layout__col--align-{{ section.settings.content_vertical_align }} image-with-layout__col--text-{{ section.settings.text_alignment }}">
      {% if section.settings.eyebrow != blank %}
        <p class="image-with-layout__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="image-with-layout__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="image-with-layout__subheading">{{ section.settings.subheading | escape }}</p>
      {% endif %}
      {% if section.settings.body_text != blank %}
        <div class="image-with-layout__body rte">{{ section.settings.body_text }}</div>
      {% endif %}
      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_url }}" class="btn {{ section.settings.button_type }} {{ section.settings.button_size }} {{ section.settings.button_style }}">
          {{ section.settings.button_text | escape }}
        </a>
      {% endif %}
    </div>

    <div class="image-with-layout__col image-with-layout__col--image">
      {% if section.settings.image_right %}
        <img
          src="{{ section.settings.image_right | image_url: width: 800 }}"
          alt="{{ section.settings.image_right_alt | default: section.settings.image_right.alt | escape }}"
          loading="lazy"
        >
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Image with layout",
  "enabled_on": {
    "templates": ["product", "collection", "page", "index", "article", "blog", "404", "cart", "search"]
  },
  "settings": [
    {
      "type": "text",
      "id": "section_anchor_id",
      "label": "Section Anchor ID (optional)"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color scheme"
    },
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_left_alt",
      "label": "Alt text",
      "info": "Defaults to image alt text if blank"
    },
    {
      "type": "header",
      "content": "Right Image"
    },
    {
      "type": "image_picker",
      "id": "image_right",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_right_alt",
      "label": "Alt text",
      "info": "Defaults to image alt text if blank"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "select",
      "id": "content_vertical_align",
      "label": "Vertical alignment",
      "default": "center",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ]
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_type",
      "label": "Color",
      "default": "btn--primary",
      "options": [
        { "value": "btn--black", "label": "Black" },
        { "value": "btn--white", "label": "White" },
        { "value": "btn--primary", "label": "Primary" },
        { "value": "btn--secondary", "label": "Secondary" }
      ]
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Size",
      "default": "",
      "options": [
        { "label": "Small", "value": "btn--small" },
        { "label": "Medium", "value": "" },
        { "label": "Large", "value": "btn--large" }
      ]
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Style",
      "default": "btn--solid",
      "options": [
        { "label": "Solid", "value": "btn--solid" },
        { "label": "Outline", "value": "btn--outline" },
        { "label": "Text", "value": "btn--text" }
      ]
    },
    {
      "type": "header",
      "content": "Padding \u2014 Desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Padding \u2014 Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Image with layout"
    }
  ]
}
{% endschema %}